# ─── That's literally all you need to set ────────────────────────────────────

# A random secret used to encrypt your stored credentials.
# Generate one at: https://generate-secret.vercel.app/64
# IMPORTANT: Never share this. If you lose it, you'll need to re-enter credentials.
ENCRYPTION_SECRET=replace_with_64_char_random_string

# Port (Railway sets this automatically — don't change unless running locally)
PORT=3000
